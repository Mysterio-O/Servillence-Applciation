# Copy this file to .env and update values.

# Database connection (external DB like Neon recommended)
DB_CONNECTION_STRING=Host=postgres;Database=surveilwin;Username=postgres;Password=postgres

# Security
JWT_SECRET=replace_with_a_strong_base64_secret_at_least_64_chars
JWT_ISSUER=surveilwin-api
JWT_AUDIENCE=surveilwin-clients
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=30

# App settings
APP_DASHBOARD_URL=http://localhost:5173
APP_SCREENSHOTS_DIR=data/screenshots
JOBS_SHIFT_AUTO_CLOSE_INTERVAL_MINUTES=60

# Optional providers
EMAIL_PROVIDER=Log
AI_PROVIDER=ollama
AI_OLLAMA_URL=http://ollama:11434
AI_OLLAMA_MODEL=llama3.2
